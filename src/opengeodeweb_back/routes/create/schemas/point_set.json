{
  "route": "/point_set",
  "methods": ["POST"],
  "type": "object",
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "points": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "x": { "type": "number" },
          "y": { "type": "number" },
          "z": { "type": "number" }
        },
        "required": ["x", "y", "z"]
      },
      "minItems": 1
    }
  },
  "required": ["name", "points"],
  "additionalProperties": false
}
